    def split_worldbook(self, json_file: str, output_dir: str = None) -> None:
        """
        拆分JSON世界书为TXT文件
        
        Args:
            json_file: JSON文件路径
            output_dir: 输出目录（如果指定，则在该目录下创建以世界书名称命名的子目录）
        """
        print(f"正在拆分世界书: {json_file}")
        
        json_path = Path(json_file)
        if not json_path.exists():
            print(f"错误: 文件不存在 - {json_file}")
            return
        
        # 获取世界书名称
        worldbook_name = self.json_parser.get_worldbook_name_from_file(json_file)
        
        # 如果指定了输出目录，则在该目录下创建以世界书名称命名的子目录
        if output_dir is None:
            base_dir = self.config.get_directory('txt')
            output_dir = base_dir / worldbook_name
        else:
            base_dir = Path(output_dir)
            output_dir = base_dir / worldbook_name
        
        ensure_directory_exists(output_dir)
        
        try:
            metadata, entries = self.json_parser.parse_worldbook_json(json_file)
            
            print(f"找到 {len(entries)} 个条目")
            
            generated_files = self.txt_generator.batch_generate_txt(
                entries, 
                str(output_dir), 
                worldbook_name
            )
            
            print(f"成功生成 {len(generated_files)} 个TXT文件")
            print(f"输出目录: {output_dir}")
            
            stats = self.json_parser.get_entry_statistics(entries)
            print(f"\n统计信息:")
            print(f"  总条目数: {stats['total']}")
            print(f"  常量条目: {stats['constant']}")
            print(f"  可选条目: {stats['selective']}")
            print(f"  启用条目: {stats['enabled']}")
            print(f"  禁用条目: {stats['disabled']}")
            
        except Exception as e:
            print(f"拆分失败: {e}")
            import traceback
            traceback.print_exc()
    
