    def merge_by_uid_range(self, output_name: str, uid_start: int, uid_end: int, 
                          txt_dir: str = None, output_dir: str = None,
                          format: str = 'new') -> None:
        """
        按UID范围合并TXT文件为JSON世界书
        
        Args:
            output_name: 输出世界书名称
            uid_start: 起始UID
            uid_end: 结束UID
            txt_dir: TXT目录
            output_dir: 输出目录
            format: 输出格式（'new'或'old'）
        """
        print(f"正在按UID范围合并世界书: {output_name}")
        print(f"UID范围: {uid_start} - {uid_end}")
        print(f"输出格式: {format}")
        
        if txt_dir is None:
            txt_dir = self.config.get_directory('txt')
        else:
            txt_dir = Path(txt_dir)
        
        if output_dir is None:
            output_dir = self.config.get_directory('json_new')
        else:
            output_dir = Path(output_dir)
        
        ensure_directory_exists(output_dir)
        
        try:
            # 获取所有TXT文件
            txt_files = list(txt_dir.glob('*.txt'))
            
            # 筛选指定UID范围的文件
            selected_files = []
            for txt_file in txt_files:
                # 从文件内容中读取UID（而不是从文件名）
                try:
                    content = load_text_file(str(txt_file))
                    uid = self.txt_parser.get_uid_from_content(content)
                except:
                    uid = None
                
                if uid is not None and uid_start <= uid <= uid_end:
                    selected_files.append(str(txt_file))
            
            print(f"找到 {len(selected_files)} 个匹配的TXT文件")
            
            if not selected_files:
                print("没有找到匹配的TXT文件")
                return
            
            # 解析TXT文件
            entries = self.txt_parser.batch_parse_txt(selected_files)
            
            print(f"成功解析 {len(entries)} 个条目")
            
            output_file = output_dir / f"{output_name}.json"
            
            metadata = {
                'name': output_name,
                'description': f'从UID {uid_start}-{uid_end} 的 {len(selected_files)} 个TXT文件合并',
            }
            
            self.json_generator.generate_worldbook_json(entries, str(output_file), metadata, format)
            
            print(f"成功生成JSON文件: {output_file}")
            
            stats = self.json_generator.get_entry_statistics(entries)
            print(f"\n统计信息:")
            print(f"  总条目数: {stats['total']}")
            print(f"  常量条目: {stats['constant']}")
            print(f"  可选条目: {stats['selective']}")
            print(f"  启用条目: {stats['enabled']}")
            print(f"  禁用条目: {stats['disabled']}")
            print(f"  Order范围: {stats['order_range']['min']} - {stats['order_range']['max']}")
            
        except Exception as e:
            print(f"合并失败: {e}")
            import traceback
            traceback.print_exc()
    
    def batch_set_uid(self, uid_spec: str, txt_dir: str = None) -> None:
        """
        批量设置UID
        
        Args:
            uid_spec: UID规格（范围"1-100"或列表"1,7,10,100"）
            txt_dir: TXT目录
        """
        print(f"正在批量设置UID: {uid_spec}")
        
        if txt_dir is None:
            txt_dir = self.config.get_directory('txt')
        else:
            txt_dir = Path(txt_dir)
        
        try:
            # 解析UID规格
            uid_list = self._parse_uid_spec(uid_spec)
            
            # 获取所有TXT文件
            txt_files = list(txt_dir.glob('*.txt'))
            txt_files.sort(key=lambda x: x.name)
            
            if len(uid_list) != len(txt_files):
                print(f"警告: UID数量({len(uid_list)})与文件数量({len(txt_files)})不匹配")
            
            print(f"找到 {len(txt_files)} 个TXT文件需要更新")
            
            updated_count = 0
            for i, txt_file in enumerate(txt_files):
                if i >= len(uid_list):
                    break
                
                try:
                    content = load_text_file(str(txt_file))
                    lines = content.split('\n')
                    
                    # 查找并替换UID行
                    for j, line in enumerate(lines):
                        if line.strip().startswith("UID:"):
                            lines[j] = f"UID: {uid_list[i]}"
                            break
                    
                    # 保存文件
                    save_text_file('\n'.join(lines), str(txt_file))
                    updated_count += 1
                    
                except Exception as e:
                    print(f"更新失败 {txt_file.name}: {e}")
            
            print(f"成功更新 {updated_count} 个文件")
            
        except Exception as e:
            print(f"批量设置UID失败: {e}")
            import traceback
            traceback.print_exc()
    
    def _parse_uid_spec(self, uid_spec: str) -> List[int]:
        """
        解析UID规格
        
        Args:
            uid_spec: UID规格（范围"1-100"或列表"1,7,10,100"）
            
        Returns:
            UID列表
        """
        if '-' in uid_spec:
            # 范围格式："1-100"
            start, end = map(int, uid_spec.split('-'))
            return list(range(start, end + 1))
        elif ',' in uid_spec:
            # 列表格式："1,7,10,100"
            return [int(uid.strip()) for uid in uid_spec.split(',')]
        else:
            # 单个UID
            return [int(uid_spec)]
    
