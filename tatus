    def extract_by_key(self, source_dir: str, keywords: str, output_dir: str = None) -> None:
        """
        根据指定的关键词提取包含该关键词的TXT文件到指定目录
        
        Args:
            source_dir: 源TXT目录
            keywords: 关键词（单个"XX"或多个"XX,YY,ZZ"）
            output_dir: 输出目录（默认: TXT/extracted/{源目录名}/）
        """
        print(f"正在根据关键词提取TXT文件")
        
        source_path = Path(source_dir)
        if not source_path.exists():
            print(f"错误: 源目录不存在 - {source_dir}")
            return
        
        if output_dir is None:
            output_dir = self.config.get_directory('txt') / 'extracted' / source_path.name
        else:
            output_dir = Path(output_dir)
        
        ensure_directory_exists(output_dir)
        
        try:
            txt_files = list(source_path.glob('*.txt'))
            print(f"找到 {len(txt_files)} 个TXT文件")
            
            keyword_list = [k.strip() for k in keywords.split(',')]
            print(f"提取关键词: {', '.join(keyword_list)}")
            
            matched_files = []
            
            for txt_file in txt_files:
                try:
                    entry = self.txt_parser.parse_txt_file(str(txt_file))
                    keys = entry.get('key', [])
                    
                    if keys:
                        for keyword in keyword_list:
                            if keyword in keys:
                                matched_files.append(txt_file)
                                break
                except Exception as e:
                    print(f"解析失败 {txt_file.name}: {e}")
            
            print(f"找到 {len(matched_files)} 个包含指定关键词的文件")
            
            moved_count = 0
            for txt_file in matched_files:
                dest_file = output_dir / txt_file.name
                shutil.move(str(txt_file), str(dest_file))
                moved_count += 1
                print(f"移动: {txt_file.name}")
            
            print(f"成功移动 {moved_count} 个文件到 {output_dir}")
            
        except Exception as e:
            print(f"提取失败: {e}")
            import traceback
            traceback.print_exc()
    
    def add_keywords(self, keywords: str, txt_dir: str, uid: int) -> None:
        """
        为指定UID的TXT文件添加关键字
        
        Args:
            keywords: 关键字（单个"XX"或多个"XX,YY,ZZ"）
            txt_dir: TXT目录
            uid: 指定UID
        """
        print(f"正在为UID {uid} 添加关键字: {keywords}")
        
        txt_path = Path(txt_dir)
        if not txt_path.exists():
            print(f"错误: 目录不存在 - {txt_dir}")
            return
        
        try:
            txt_files = list(txt_path.glob('*.txt'))
            
            target_file = None
            for txt_file in txt_files:
                # 从文件内容中读取UID（而不是从文件名）
                try:
                    content = load_text_file(str(txt_file))
                    file_uid = self.txt_parser.get_uid_from_content(content)
                except:
                    file_uid = None
                
                if file_uid == uid:
                    target_file = txt_file
                    break
            
            if not target_file:
                print(f"错误: 未找到UID为 {uid} 的TXT文件")
                return
            
            content = load_text_file(str(target_file))
            lines = content.split('\n')
            
            keyword_list = [k.strip() for k in keywords.split(',')]
            
            for i, line in enumerate(lines):
                if line.strip().startswith("Key:"):
                    existing_keys = line.split(':', 1)[1].strip()
                    if existing_keys and existing_keys != '[]':
                        try:
                            import json
                            existing_list = json.loads(existing_keys)
                            keyword_list = existing_list + keyword_list
                        except:
                            pass
                    
                    import json
                    new_keys = json.dumps(keyword_list, ensure_ascii=False)
                    lines[i] = f"Key: {new_keys}"
                    break
            
            save_text_file('\n'.join(lines), str(target_file))
            print(f"成功添加 {len(keyword_list)} 个关键字到 {target_file.name}")
            
        except Exception as e:
            print(f"添加关键字失败: {e}")
            import traceback
            traceback.print_exc()
    
